{
  "manifest_version": 3,
  "name": "tabcli",
  "version": "0.3.0",
  "key": "",
  "minimum_chrome_version": "121",
  "description": "Organize current Chrome tabs through a local, approval-gated MCP server.",
  "options_page": "options.html",
  "permissions": ["tabs", "tabGroups", "storage", "scripting", "nativeMessaging"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "dist/service-worker.js",
    "type": "module"
  }
}
